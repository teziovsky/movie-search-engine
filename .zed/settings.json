            "name": "oxfmt"
          }
        }
      ],
      "language_servers": ["!prettier", "!biome", "!graphql", "!stylelint-lsp", "..."]
    },
    "CSS": {
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
